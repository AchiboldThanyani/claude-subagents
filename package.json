{
  "name": "claude-subagents",
  "displayName": "Claude Subagents",
  "description": "Visualise and orchestrate Claude subagents — plan, review, test, document and more",
  "version": "0.3.1",
  "publisher": "achibold-lukhwareni",
  "engines": { "vscode": "^1.85.0" },
  "icon": "media/icon.png",
  "categories": ["Other", "Machine Learning"],
  "repository": {
    "type": "git",
    "url": "https://github.com/AchiboldThanyani/claude-subagents"
  },
  "license": "MIT",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "claudeSubagents.openPanel",    "title": "Claude: Open Subagents Panel",        "icon": "$(circuit-board)" },
      { "command": "claudeSubagents.runPlanner",   "title": "Claude: Plan Task with Subagents" },
      { "command": "claudeSubagents.reviewCode",   "title": "Claude: Review Code" },
      { "command": "claudeSubagents.writeTests",   "title": "Claude: Write Tests" },
      { "command": "claudeSubagents.writeDocs",    "title": "Claude: Write Docs" },
      { "command": "claudeSubagents.findBugs",     "title": "Claude: Find Bugs" },
      { "command": "claudeSubagents.gitCommit",    "title": "Claude: Write Git Commit Message" },
      { "command": "claudeSubagents.refactor",     "title": "Claude: Refactor Code" },
      { "command": "claudeSubagents.createAgent",  "title": "Claude: Create Custom Agent" },
      { "command": "claudeSubagents.openHistory",  "title": "Claude: Open Agent History" },
      { "command": "claudeSubagents.clearGraph",   "title": "Claude: Clear Agent Graph" }
    ],
    "menus": {
      "editor/context": [
        { "command": "claudeSubagents.reviewCode", "group": "9_claude@1" },
        { "command": "claudeSubagents.writeTests", "group": "9_claude@2" },
        { "command": "claudeSubagents.writeDocs",  "group": "9_claude@3" },
        { "command": "claudeSubagents.findBugs",   "group": "9_claude@4" },
        { "command": "claudeSubagents.refactor",   "when": "editorHasSelection", "group": "9_claude@5" },
        { "command": "claudeSubagents.runPlanner", "group": "9_claude@6" }
      ],
      "editor/title": [
        { "command": "claudeSubagents.openPanel",  "group": "navigation" }
      ],
      "scm/title": [
        { "command": "claudeSubagents.gitCommit",  "group": "inline" }
      ]
    },
    "keybindings": [
      { "command": "claudeSubagents.openPanel",  "key": "ctrl+shift+u", "mac": "cmd+shift+u" },
      { "command": "claudeSubagents.reviewCode", "key": "ctrl+shift+r", "mac": "cmd+shift+r" },
      { "command": "claudeSubagents.findBugs",   "key": "ctrl+shift+b", "mac": "cmd+shift+b" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1"
  }
}
